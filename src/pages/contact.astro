---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout 
  title="Contact Us" 
  description="Get in touch with Cogintech for questions, support, or partnership opportunities"
>
  <div class="space-y-12">
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-3xl font-bold mb-6 text-cogintech-blue">Get in Touch</h2>
        <p class="text-lg text-foreground/80 mb-8">
          Ready to transform your equipment integrity analysis process? 
          Our team is here to answer your questions and help you get started.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cogintech-blue/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-cogintech-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Email</h3>
              <p class="text-foreground/80">info@cogintech.ai</p>
              <p class="text-sm text-foreground/60">We respond within 24 hours</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cogintech-teal/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-cogintech-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Phone</h3>
              <p class="text-foreground/80">+1 (555) 123-COGI</p>
              <p class="text-sm text-foreground/60">Monday - Friday, 9AM - 6PM EST</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cogintech-orange/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-cogintech-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Headquarters</h3>
              <p class="text-foreground/80">Houston, Texas</p>
              <p class="text-sm text-foreground/60">Heart of the energy industry</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white p-8 rounded-lg border border-border shadow-sm">
        <h3 class="text-2xl font-bold mb-6 text-cogintech-blue">Send us a Message</h3>
        <form class="space-y-6" action="mailto:info@cogintech.ai" method="post" enctype="text/plain">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="firstName" class="block text-sm font-medium text-foreground mb-2">First Name *</label>
              <input 
                type="text" 
                id="firstName" 
                name="firstName" 
                required 
                class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
                placeholder="John"
              />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-foreground mb-2">Last Name *</label>
              <input 
                type="text" 
                id="lastName" 
                name="lastName" 
                required 
                class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
                placeholder="Smith"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-foreground mb-2">Email *</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              placeholder="john@company.com"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-foreground mb-2">Company</label>
            <input 
              type="text" 
              id="company" 
              name="company" 
              class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              placeholder="Your Company"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-foreground mb-2">Subject *</label>
            <select 
              id="subject" 
              name="subject" 
              required 
              class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
            >
              <option value="">Select a subject</option>
              <option value="demo">Request a Demo</option>
              <option value="pricing">Pricing Information</option>
              <option value="partnership">Partnership Opportunities</option>
              <option value="support">Technical Support</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-foreground mb-2">Message *</label>
            <textarea 
              id="message" 
              name="message" 
              rows="6" 
              required 
              class="w-full border border-border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              placeholder="Tell us about your inspection challenges and how we can help..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full bg-cogintech-orange hover:bg-cogintech-orange/90 text-white font-medium py-3 px-6 rounded-lg transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center p-6 bg-cogintech-blue/5 rounded-lg">
        <h3 class="text-xl font-semibold mb-2 text-cogintech-blue">Sales Inquiries</h3>
        <p class="text-foreground/80 mb-4">Ready to see how Cogintech can reduce your inspection costs?</p>
        <a href="mailto:sales@cogintech.ai" class="text-cogintech-blue hover:underline font-medium">sales@cogintech.ai</a>
      </div>

      <div class="text-center p-6 bg-cogintech-teal/5 rounded-lg">
        <h3 class="text-xl font-semibold mb-2 text-cogintech-teal">Technical Support</h3>
        <p class="text-foreground/80 mb-4">Need help with your existing Cogintech implementation?</p>
        <a href="mailto:support@cogintech.ai" class="text-cogintech-teal hover:underline font-medium">support@cogintech.ai</a>
      </div>

      <div class="text-center p-6 bg-cogintech-orange/5 rounded-lg">
        <h3 class="text-xl font-semibold mb-2 text-cogintech-orange">Partnerships</h3>
        <p class="text-foreground/80 mb-4">Interested in partnering with Cogintech?</p>
        <a href="mailto:partners@cogintech.ai" class="text-cogintech-orange hover:underline font-medium">partners@cogintech.ai</a>
      </div>
    </section>
  </div>
</PageLayout>