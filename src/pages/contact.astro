---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout 
  title="Contact Us - Get in Touch with AI Experts | Cogintech"
  description="Get in touch with our AI experts and discover how we can transform your industrial operations. Contact Cogintech for AI-powered equipment integrity solutions."
  keywords="contact Cogintech, AI experts contact, industrial AI consultation, equipment integrity contact"
  ogTitle="Contact Us - Get in Touch with AI Experts"
  ogDescription="Get in touch with our AI experts and discover how we can transform your industrial operations."
  ogImage="/lovable-uploads/22fc09d7-63fe-4527-885a-d78c38ec2e86.png"
>
  <main class="flex-1">
    {/* Hero Section */}
    <section class="relative h-64 md:h-80 bg-gradient-to-r from-cogintech-blue to-cogintech-orange flex items-center">
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2426&q=80" 
          alt="Contact Us - Technology Office" 
          class="w-full h-full object-cover opacity-20"
        />
      </div>
      <div class="container relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact Us</h1>
        <p class="text-xl text-white/90 max-w-2xl">
          Get in touch with our AI experts and discover how we can transform your industrial operations
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          <div>
            <h2 class="text-3xl font-bold mb-4">Let's Talk</h2>
            <p class="text-lg mb-8">
              Have questions about our AI-powered solutions? Get in touch with our team, and we'll be happy to help.
            </p>
            
            <div class="space-y-6 mb-8">
              <div>
                <h3 class="text-xl font-semibold mb-2">Headquarters</h3>
                <address class="not-italic">
                  Mansion House<br />
                  Manchester Road<br />
                  Altrincham<br />
                  Cheshire<br />
                  WA14 4RW<br />
                  United Kingdom
                </address>
              </div>
              
              <div>
                <h3 class="text-xl font-semibold mb-2">Email</h3>
                <p>vr@cogintech.com</p>
              </div>
            </div>
          </div>
          
          <div class="bg-card p-8 rounded-lg shadow-md">
            <h2 class="text-2xl font-bold mb-6">Send Us a Message</h2>
            <form class="space-y-4" action="mailto:vr@cogintech.com" method="post" enctype="text/plain">
              <div>
                <label for="name" class="block mb-1 font-medium">Full Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name"
                  class="w-full p-2 border border-border rounded-md" 
                  placeholder="Enter your full name"
                  required
                />
              </div>
              
              <div>
                <label for="company" class="block mb-1 font-medium">Company</label>
                <input 
                  type="text" 
                  id="company"
                  name="company"
                  class="w-full p-2 border border-border rounded-md" 
                  placeholder="Enter your company name" 
                />
              </div>
              
              <div>
                <label for="email" class="block mb-1 font-medium">Email</label>
                <input 
                  type="email" 
                  id="email"
                  name="email"
                  class="w-full p-2 border border-border rounded-md"
                  placeholder="Enter your email address"
                  required
                />
              </div>
              
              <div>
                <label for="phone" class="block mb-1 font-medium">Phone</label>
                <input 
                  type="tel" 
                  id="phone"
                  name="phone"
                  class="w-full p-2 border border-border rounded-md" 
                  placeholder="Enter your phone number" 
                />
              </div>
              
              <div>
                <label for="message" class="block mb-1 font-medium">Message</label>
                <textarea 
                  id="message"
                  name="message"
                  rows={4} 
                  class="w-full p-2 border border-border rounded-md" 
                  placeholder="How can we help you?"
                />
              </div>
              
              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <input 
                    type="checkbox" 
                    id="privacy-policy"
                    name="privacy-policy"
                    class="mt-1"
                    required
                  />
                  <label for="privacy-policy" class="text-sm leading-relaxed">
                    I agree to the{' '}
                    <a 
                      href="/privacy-policy" 
                      class="text-cogintech-blue hover:underline"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Privacy Policy
                    </a>
                  </label>
                </div>
                
                <div class="flex items-start space-x-3">
                  <input 
                    type="checkbox" 
                    id="terms-of-service"
                    name="terms-of-service"
                    class="mt-1"
                    required
                  />
                  <label for="terms-of-service" class="text-sm leading-relaxed">
                    I agree to the{' '}
                    <a 
                      href="/terms-of-service" 
                      class="text-cogintech-blue hover:underline"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Terms of Service
                    </a>
                  </label>
                </div>
              </div>

              <button 
                type="submit" 
                class="w-full bg-cogintech-orange hover:bg-cogintech-orange/90 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium px-6 py-2 rounded-md transition-colors"
              >
                Submit
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>