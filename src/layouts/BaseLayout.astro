---
import BaseHead from '@/components/BaseHead.astro';
import '@/styles/globals.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, image, type, canonical, noindex } = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      image={image} 
      type={type} 
      canonical={canonical}
      noindex={noindex}
    />
  </head>
  <body>
    <slot />
  </body>
</html>