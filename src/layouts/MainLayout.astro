---
import BaseHead from '@/components/BaseHead.astro';
import Navbar from '@/components/astro/Navbar.astro';
import Footer from '@/components/astro/Footer.astro';
import CookieConsent from '@/components/astro/CookieConsent.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  noindex?: boolean;
  withNavbar?: boolean;
  withFooter?: boolean;
  containerClass?: string;
}

const { 
  title, 
  description, 
  image, 
  type, 
  canonical, 
  noindex,
  withNavbar = true,
  withFooter = true,
  containerClass = "min-h-screen"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      image={image} 
      type={type} 
      canonical={canonical}
      noindex={noindex}
    />
  </head>
  <body class="bg-background text-foreground">
    {withNavbar && (
      <Navbar currentPath={Astro.url.pathname} />
    )}
    
    <main class={containerClass}>
      <slot />
    </main>
    
    {withFooter && (
      <Footer />
    )}
    
    <CookieConsent />
  </body>
</html>