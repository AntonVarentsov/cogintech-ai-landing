---
const solutions = [
  {
    title: "Document Manager",
    description: "Centralize all integrity documents with AI-powered search and instant access to critical information.",
    benefits: "Find any document in seconds, not hours.",
    video: "/lovable-uploads/import_pdf.mp4",
    ctaText: "See Document Manager"
  },
  {
    title: "Dashboard + AI Assistant",
    description: "Real-time equipment health monitoring with intelligent insights and predictive alerts.",
    benefits: "Prevent failures before they happen.",
    video: "/lovable-uploads/dashboard.mp4",
    ctaText: "View Dashboard Demo"
  },
  {
    title: "Smart AI Tools",
    description: "Advanced corrosion loop analysis and risk assessment. Recent case: prevented $30k failure at offshore platform.",
    benefits: "AI-powered analysis saves millions.",
    video: "/lovable-uploads/corrosion_loops.mp4",
    ctaText: "Try AI Tools"
  },
  {
    title: "AI Assistant",
    description: "Ask simple questions in natural language and get insights instantly. No special training required.",
    benefits: "Get instant answers from your data without complex commands.",
    video: "/lovable-uploads/AI_assistant.mp4",
    ctaText: "Try AI Assistant"
  }
];
---

<section id="solution" class="py-16">
  <div class="container">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold mb-4">
        See how <span class="gradient-text">AI transforms</span> your workflow
      </h2>
      <p class="text-xl text-foreground/70 max-w-3xl mx-auto">
        Four core tools that eliminate information chaos and prevent costly failures.
      </p>
    </div>
    
    <div class="space-y-24">
      {solutions.map((solution, index) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:grid-flow-col-dense' : ''}`}>
          <div class={`space-y-6 ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-cogintech-orange/10 rounded-lg flex items-center justify-center">
                {index === 0 && (
                  <svg class="h-6 w-6 text-cogintech-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14,2 14,8 20,8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10,9 9,9 8,9"></polyline>
                  </svg>
                )}
                {index === 1 && (
                  <svg class="h-6 w-6 text-cogintech-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                )}
                {index === 2 && (
                  <svg class="h-6 w-6 text-cogintech-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"></path>
                    <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"></path>
                  </svg>
                )}
                {index === 3 && (
                  <svg class="h-6 w-6 text-cogintech-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  </svg>
                )}
              </div>
              <h3 class="text-2xl font-bold">{solution.title}</h3>
            </div>
            
            <p class="text-lg text-foreground/80">{solution.description}</p>
            
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <p class="text-green-700 font-medium">{solution.benefits}</p>
            </div>
            
            <button 
              class="border border-cogintech-blue text-cogintech-blue hover:bg-cogintech-blue/5 font-medium px-8 py-3 rounded-lg transition-colors"
              onclick="document.getElementById('demo-form')?.scrollIntoView({ behavior: 'smooth' })"
            >
              {solution.ctaText}
            </button>
          </div>
          
          <div 
            class={`relative aspect-[2/1] rounded-xl overflow-hidden bg-white border border-gray-200 shadow-sm cursor-pointer hover:opacity-90 transition-opacity ${index % 2 === 1 ? 'lg:col-start-1' : ''}`}
            onclick={`openSolutionVideoModal('${solution.video}')`}
            tabindex="0"
            role="button"
            aria-label={`Открыть видео демонстрацию: ${solution.title}`}
          >
            <video 
              src={solution.video} 
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              class="w-full h-full object-contain"
              aria-label={`Демонстрация: ${solution.title}`}
            ></video>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Modal -->
  <div id="solution-video-modal" class="fixed inset-0 bg-black/90 flex items-center justify-center z-50 hidden" onclick="closeSolutionVideoModal()">
    <div class="relative w-full h-full flex items-center justify-center p-4">
      <button 
        onclick="closeSolutionVideoModal()"
        class="absolute top-4 right-4 z-10 bg-white/20 hover:bg-white/40 text-white rounded-full p-3 transition-colors"
        aria-label="Закрыть видео"
        title="Закрыть видео"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="w-full h-full flex items-center justify-center">
        <video 
          id="solution-modal-video"
          autoplay
          muted
          loop
          playsinline
          class="w-auto h-auto max-w-full max-h-full object-contain" 
          style="max-width: 95vw; max-height: 95vh;"
        />
      </div>
    </div>
  </div>
</section>

<script>
  function openSolutionVideoModal(videoSrc) {
    const modal = document.getElementById('solution-video-modal');
    const video = document.getElementById('solution-modal-video');
    if (modal && video) {
      video.src = videoSrc;
      modal.classList.remove('hidden');
    }
  }
  
  function closeSolutionVideoModal() {
    const modal = document.getElementById('solution-video-modal');
    const video = document.getElementById('solution-modal-video');
    if (modal && video) {
      modal.classList.add('hidden');
      video.src = '';
    }
  }
  
  // Close modal on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeSolutionVideoModal();
    }
  });
</script>