---
// SocialProof component - exact copy from original
---

<section id="testimonials" class="py-16">
  <div class="container">
    <div class="bg-gradient-to-br from-cogintech-blue/5 via-cogintech-teal/5 to-cogintech-blue/10 rounded-2xl border border-cogintech-blue/20 p-12 text-center relative overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-cogintech-blue/5 rounded-full -translate-y-16 translate-x-16"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-cogintech-teal/5 rounded-full translate-y-12 -translate-x-12"></div>
      
      <div class="relative z-10">
        <div class="flex justify-center mb-6">
          <div class="bg-cogintech-blue/10 p-4 rounded-full">
            <svg class="w-8 h-8 text-cogintech-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4.5 16.5c-1.5 1.5-1.5 3.5 0 5s3.5 1.5 5 0l.5-.5.5.5c1.5 1.5 3.5 1.5 5 0s1.5-3.5 0-5L12 13l-7.5 3.5z"></path>
              <path d="M15 6.5L8.5 10 12 13l7.5-3.5L15 6.5z"></path>
            </svg>
          </div>
        </div>
        
        <h2 class="text-4xl font-bold mb-4 bg-gradient-to-r from-cogintech-blue to-cogintech-teal bg-clip-text text-transparent">
          Join Early Adopters
        </h2>
        
        <p class="text-xl text-foreground/70 max-w-2xl mx-auto mb-4">
          Be among the first to experience revolutionary AI-driven integrity management with leading enterprises.
        </p>
        
        <div class="flex flex-wrap justify-center gap-6 mb-8 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cogintech-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22,4 12,14.01 9,11.01"></polyline>
            </svg>
            <span class="text-foreground/80">Exclusive pilot access</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cogintech-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span class="text-foreground/80">Direct expert support</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cogintech-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
            <span class="text-foreground/80">Early bird benefits</span>
          </div>
        </div>
        
        <button 
          class="bg-gradient-to-r from-cogintech-blue to-cogintech-teal hover:from-cogintech-blue/90 hover:to-cogintech-teal/90 text-white px-8 py-3 text-lg font-semibold shadow-lg hover:shadow-xl transition-all duration-300 rounded-lg"
          onclick="document.getElementById('demo-form')?.scrollIntoView({ behavior: 'smooth' })"
        >
          Join the Program
        </button>
        
        <p class="text-sm font-semibold text-cogintech-blue/80 mt-4">
          Limited slots available
        </p>
      </div>
    </div>
  </div>
</section>