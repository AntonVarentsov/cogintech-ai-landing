---
const metrics = [
  {
    value: "30%",
    label: "Reduction in unplanned failures",
    description: "Prevent costly equipment breakdowns with predictive insights",
    icon: "calendar"
  },
  {
    value: "100x",
    label: "Faster information search",
    description: "Find critical documents and data in seconds, not hours",
    icon: "zap"
  },
  {
    value: "95%+",
    label: "Analysis accuracy",
    description: "AI-powered precision in integrity assessments",
    icon: "shield"
  },
  {
    value: "$10M",
    label: "Average annual savings",
    description: "Typical cost reduction from prevented failures and efficiency gains",
    icon: "dollar-sign"
  }
];
---

<section id="results" class="py-16 bg-gradient-to-b from-cogintech-blue/5 to-background">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">
        Quantified <span class="text-green-600">value</span> from day one
      </h2>
      <p class="text-xl text-foreground/70 max-w-3xl mx-auto">
        Real results from customers using our AI-powered integrity management platform.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {metrics.map((metric, index) => (
        <div class="text-center p-6 rounded-xl bg-white shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center">
              {metric.icon === "calendar" && (
                <svg class="h-6 w-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
              )}
              {metric.icon === "zap" && (
                <svg class="h-6 w-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              )}
              {metric.icon === "shield" && (
                <svg class="h-6 w-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              )}
              {metric.icon === "dollar-sign" && (
                <svg class="h-6 w-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23"></line>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
              )}
            </div>
          </div>
          <div class="text-4xl font-bold text-cogintech-orange mb-2">
            {metric.value}
          </div>
          <h3 class="text-lg font-semibold mb-3 text-foreground">
            {metric.label}
          </h3>
          <p class="text-sm text-foreground/70">
            {metric.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>