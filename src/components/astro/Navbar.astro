            <button class="flex items-center text-base text-foreground/80 hover:text-cogintech-blue transition-colors dropdown-trigger">
              Company 
              <svg class="ml-1 h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6,9 12,15 18,9"></polyline>
              </svg>
            </button>
            <div class="dropdown-content absolute top-full left-0 mt-1 bg-background border border-border shadow-lg rounded-md py-1 min-w-[150px] z-50 hidden">
              <a href="/about-us" class="block px-4 py-2 text-base text-foreground/80 hover:text-cogintech-blue hover:bg-accent transition-colors">About Us</a>
              <a href="/our-team" class="block px-4 py-2 text-base text-foreground/80 hover:text-cogintech-blue hover:bg-accent transition-colors">Our Team</a>
              <a href="/careers" class="block px-4 py-2 text-base text-foreground/80 hover:text-cogintech-blue hover:bg-accent transition-colors">Careers</a>
