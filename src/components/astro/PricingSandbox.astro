---
// PricingSandbox component - exact copy from original
---

<section id="pricing" class="py-16">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">
        Try before you buy
      </h2>
      <p class="text-xl text-foreground/70 max-w-3xl mx-auto">
        Get instant access to a read-only sandbox environment with sample data.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Pricing Info -->
      <div class="space-y-6">
        <div class="border border-border bg-card text-card-foreground rounded-lg shadow-sm">
          <div class="p-6 pb-0">
            <h3 class="text-xl font-semibold">Enterprise Pricing</h3>
            <p class="text-foreground/70">Flexible pricing based on your infrastructure scale</p>
          </div>
          <div class="p-6 space-y-4">
            <div class="space-y-2">
              <div class="flex justify-between">
                <span>Small operations (1-50 assets)</span>
                <span class="font-semibold">$5K-15K/month</span>
              </div>
              <div class="flex justify-between">
                <span>Medium operations (50-200 assets)</span>
                <span class="font-semibold">$15K-40K/month</span>
              </div>
              <div class="flex justify-between">
                <span>Large operations (200+ assets)</span>
                <span class="font-semibold">Custom pricing</span>
              </div>
            </div>
            <div class="pt-4 border-t">
              <p class="text-sm text-foreground/70">
                All plans include: AI analysis, 24/7 support, custom integrations, and dedicated success manager.
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Sandbox Form -->
      <div class="border border-border bg-card text-card-foreground rounded-lg shadow-sm">
        <div class="p-6 pb-0">
          <h3 class="text-xl font-semibold">Access Sandbox Environment</h3>
          <p class="text-foreground/70">Explore our platform with real-world sample data</p>
        </div>
        <div class="p-6 space-y-4">
          <form onsubmit="handleSandboxSubmit(event)" class="space-y-4">
            <div class="space-y-2">
              <label for="sandbox-email" class="block text-sm font-medium">Work Email</label>
              <input 
                id="sandbox-email" 
                name="email"
                type="email" 
                placeholder="your.email@company.com"
                required
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              />
            </div>
            <div class="space-y-2">
              <label for="sandbox-company" class="block text-sm font-medium">Company Name</label>
              <input 
                id="sandbox-company" 
                name="company"
                type="text" 
                placeholder="Your Company"
                required 
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              />
            </div>
            <div class="space-y-2">
              <label for="sandbox-role" class="block text-sm font-medium">Your Role</label>
              <input 
                id="sandbox-role" 
                name="role"
                type="text" 
                placeholder="e.g., Integrity Engineer"
                required 
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cogintech-blue/50"
              />
            </div>
            
            <div class="space-y-3">
              <div class="flex items-start space-x-3">
                <input 
                  id="privacy-policy-sandbox"
                  type="checkbox"
                  required
                  class="mt-1"
                />
                <label for="privacy-policy-sandbox" class="text-sm text-foreground/80 leading-relaxed">
                  I agree to the{' '}
                  <a 
                    href="/privacy-policy" 
                    class="text-cogintech-teal hover:underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Privacy Policy
                  </a>
                </label>
              </div>
              
              <div class="flex items-start space-x-3">
                <input 
                  id="terms-of-service-sandbox"
                  type="checkbox"
                  required
                  class="mt-1"
                />
                <label for="terms-of-service-sandbox" class="text-sm text-foreground/80 leading-relaxed">
                  I agree to the{' '}
                  <a 
                    href="/terms-of-service" 
                    class="text-cogintech-teal hover:underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Terms of Service
                  </a>
                </label>
              </div>
            </div>

            <button 
              type="submit"
              class="w-full bg-cogintech-orange hover:bg-cogintech-orange/90 text-white font-medium py-2 px-4 rounded-lg transition-colors"
            >
              Get Instant Sandbox Access
            </button>
          </form>
          <p class="text-xs text-foreground/60 text-center">
            You'll receive login credentials within 2 minutes
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function handleSandboxSubmit(event) {
    event.preventDefault();
    // Simple form handling - would normally integrate with backend
    alert('Thank you! You\'ll receive sandbox access credentials within 2 minutes.');
    event.target.reset();
  }
</script>