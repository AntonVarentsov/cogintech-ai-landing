---
const painPoints = [
  {
    title: "Information Chaos",
    description: "Critical data scattered across multiple systems, making decisions slow and error-prone."
  },
  {
    title: "No Holistic View", 
    description: "Fragmented insights prevent seeing the full picture of equipment health and risk."
  },
  {
    title: "Overloaded Engineers",
    description: "Teams spend 70% of time searching for information instead of solving problems."
  }
];
---

<section id="problem" class="py-16 bg-gradient-to-b from-background to-gray-50/50">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">
        Why do <span class="text-red-600">sudden failures</span> keep happening?
      </h2>
      <p class="text-xl text-foreground/70 max-w-3xl mx-auto">
        Three critical gaps in traditional integrity management are costing your organization millions.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {painPoints.map((point, index) => (
        <div class="text-center p-6 rounded-xl bg-white shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            {index === 0 && (
              <!-- FileX icon - Lucide FileX -->
              <svg class="h-8 w-8 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14,2 14,8 20,8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10,9 9,9 8,9"></polyline>
                <path d="m14.5 12.5-5 5"></path>
                <path d="m9.5 12.5 5 5"></path>
              </svg>
            )}
            {index === 1 && (
              <!-- AlertTriangle icon - Lucide AlertTriangle -->
              <svg class="h-8 w-8 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path>
                <path d="M12 9v4"></path>
                <path d="m12 17 .01 0"></path>
              </svg>
            )}
            {index === 2 && (
              <!-- Users icon - exact Lucide SVG -->
              <svg class="h-8 w-8 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            )}
          </div>
          <h3 class="text-xl font-semibold mb-3">{point.title}</h3>
          <p class="text-foreground/70">{point.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>